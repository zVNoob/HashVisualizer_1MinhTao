<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<fx:root dividerPositions="0.7137096774193549" orientation="VERTICAL" type="SplitPane" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26">
   <items>
      <VBox prefHeight="0.0">
         <children>
            <Label alignment="CENTER" maxWidth="1.7976931348623157E308" text="Code" />
            <ScrollPane fx:id="codeScrollPane" fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" pannable="true" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="codeArea" prefHeight="5000.0" />
               </content>
            </ScrollPane>
            <Label alignment="TOP_LEFT" text="Status: ">
               <padding>
                  <Insets left="5.0" />
               </padding>
            </Label>
         </children>
      </VBox>
      <VBox alignment="TOP_CENTER">
         <children>
            <Label alignment="TOP_LEFT" text="Variable" />
            <TableView fx:id="varTable" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="varName" maxWidth="500.0" prefWidth="100.0" text="Name" />
                <TableColumn fx:id="varValue" minWidth="200.0" prefWidth="-1.0" text="Value" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </items>
</fx:root>
